#!/usr/bin/env bash
# danus CLI — the main agent's control surface over codex workers.
# Self-locates the repo and sources the env, so it works without setup.
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HERE/../scripts/env.sh"
exec "$DANUS_PY" -m danus.orchestration "$@"
