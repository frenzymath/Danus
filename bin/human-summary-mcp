#!/usr/bin/env bash
# human-summary-mcp — launches the human-summary MCP service (role=main) for
# Claude Code (.mcp.json) or any MCP client. Sources env so DANUS_AGENTS_ROOT
# etc. are set, and exports DANUS_HUMAN_SUMMARY_SKILL_DIR so the assembler finds
# the operator-editable fixed writer prompt (agents/skills/human-summary/REPORT_WRITER_PROMPT.md).
set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$HERE/../scripts/env.sh" >/dev/null 2>&1
export DANUS_ROLE="${DANUS_ROLE:-main}"
export DANUS_AUTHOR="${DANUS_AUTHOR:-main_agent}"
export DANUS_HUMAN_SUMMARY_SKILL_DIR="${DANUS_HUMAN_SUMMARY_SKILL_DIR:-$DANUS_ROOT/agents/skills/human-summary}"
exec "$DANUS_PY" -m danus.human_summary "$@"
