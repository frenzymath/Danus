# =============================================================================
# write-paper push driver — LaTeX git remote credentials.
#
#   cp config/latex-git.env.example config/latex-git.env   # then edit + chmod 600
#
# The write-paper skill's push driver (.claude/skills/write-paper/driver/
# latex_git_push.sh) reads these to push a produced paper to any git remote that
# serves the paper repo over HTTPS with token (HTTP Basic) auth — Overleaf,
# GitHub, GitLab. Pushing is an operator-gated outward action.
#
# This file is gitignored (only *.env.example is committed). NEVER commit a real
# token.
# =============================================================================
LATEX_GIT_URL=<paper repo URL, e.g. Overleaf: https://git.overleaf.com/<project-id>>
LATEX_GIT_TOKEN=<your git access token>

# Optional: the commit author identity (plain academic commits, no AI trailer).
# LATEX_GIT_AUTHOR_NAME=
# LATEX_GIT_AUTHOR_EMAIL=
